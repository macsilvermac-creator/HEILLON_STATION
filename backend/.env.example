# Copiar para backend/.env e preencher após criar o projeto Supabase

# SQLite (desenvolvimento local — padrão actual)
# DATABASE_URL=sqlite:///./data/heillon.db

# Supabase Postgres (produção — após Fase de integração backend)
# Dashboard → Settings → Database → Connection string (URI, pooler 6543)
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

ENVIRONMENT=development
AUTH_SECRET_KEY=change-me-min-32-chars-for-jwt-signing
FERNET_ENCRYPTION_KEY=
CORS_ORIGINS=["http://localhost:3000","https://heillon-legal-ui.vercel.app"]
MISSION_ROUTES_REQUIRE_AUTH=true

# Painel do beta (/admin) — token compartilhado do operador.
# Vazio = endpoints /admin/* retornam 503. Defina um segredo forte em produção.
HEILLON_ADMIN_TOKEN=

# Observability — Sentry (opcional). Vazio = desativado (zero overhead).
# Em produção: pip install sentry-sdk e defina o DSN.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# E-mail transacional — Postmark. Vazio = modo stub (apenas loga, não envia).
POSTMARK_SERVER_TOKEN=
EMAIL_FROM=nao-responda@heillon.local
